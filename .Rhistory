pmhfu_asthma_age = as.numeric(pmhfu_asthma_age),
pmhfu_aspiration_age = ifelse(pmhfu_aspiration_age == "?4", "4", pmhfu_aspiration_age), pmhfu_aspiration_age = as.numeric(pmhfu_aspiration_age),
pmhfu_constip_age = sapply(strsplit(pmhfu_constip_age," "), `[`, 1), pmhfu_constip_age = as.numeric(pmhfu_constip_age),
