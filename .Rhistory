## Libraries
library(tidyverse)
## Data
carey <- read.csv("/Volumes/Shared/Shared Projects/Bothwell/Peds ENDO/SCA Studies/Archived/Louderman - Baby Study/Data/CareyScores_2025-05-28_1306.csv")
items <- read.csv("/Volumes/Shared/Shared Projects/Bothwell/Peds ENDO/SCA Studies/Archived/Louderman - Baby Study/Data/CareyScoresAndItems_2025-05-28_1341.csv")
## Clean data
carey_clean <- carey %>%
# filter out test record
filter(!(study_id_extraordinary == "test")) %>%
# clean race and ethnicity
mutate(race = ifelse(ses_patient_race___1 + ses_patient_race___2 + ses_patient_race___3 + ses_patient_race___4 + ses_patient_race___5 > 1, 6,
ifelse(ses_patient_race___1 == 1, 1, ifelse(ses_patient_race___2 == 1, 2, ifelse(ses_patient_race___3 == 1, 3,
ifelse(ses_patient_race___4 == 1, 4, ifelse(ses_patient_race___5 == 1, 5, ifelse(ses_patient_race___7 == 1, 7, NA)))))))) %>%
# apply sca condition to all records
group_by(study_id_extraordinary) %>%
dplyr::mutate(sca_condition = suppressWarnings(max(sca_condition, na.rm = T))) %>%
# apply race and ethnicity to all records
dplyr::mutate(race = suppressWarnings(max(race, na.rm = T))) %>%
dplyr::mutate(ses_patient_ethnicity = suppressWarnings(max(ses_patient_ethnicity, na.rm = T))) %>%
ungroup() %>%
# filter to only SCA conditions 1:3 (may change)
filter(sca_condition %in% c(1:3)) %>%
# filter to 2, 6, 12, 24, and 36 months
filter(redcap_event_name %in% c("2_month_visit_arm_1", "6_month_visit_arm_1", "12_month_visit_arm_1", "24_month_visit_arm_1", "36_month_visit_arm_1")) %>%
# select needed variables
dplyr::select(study_id_extraordinary, redcap_event_name, sca_condition, race, ses_patient_ethnicity, hollingshead_family,
age_visit_m, contains("cts_")) %>%
# filter to cts done
filter(cts_scores_done == 1) %>%
# recode race and ethncity
dplyr::mutate(sca_condition = factor(sca_condition, levels = c(1:3), labels = c("XXY", "XYY", "XXX"))) %>%
dplyr::mutate(race = factor(race, levels = c(1, 3, 4, 5, 6, 7), labels = c("White", "African American or Black", "Asian",
