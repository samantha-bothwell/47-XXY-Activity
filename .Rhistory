#### Developmental milestones
## Milestone ages
hadh_clean$sca_condition <- dems$sca_condition[match(hadh_clean$study_id_extraordinary, dems$study_id_extraordinary)]
milestones <- hadh_clean %>%
# filter to only IDs that are in the dems dataset
filter(study_id_extraordinary %in% dems$study_id_extraordinary) %>%
# f2b age needs to be numeric
mutate(devfu_rolling_f2b_age = as.numeric(devfu_rolling_f2b_age)) %>%
mutate(devfu_rolling_f2b_age = ifelse(devfu_rolling_f2b_age > 40, NA, devfu_rolling_f2b_age)) %>%
mutate(devfu_coo_age = ifelse(devfu_coo_age > 40, NA, devfu_coo_age)) %>%
mutate(devfu_crawl_age = ifelse(devfu_crawl_age > 40, NA, devfu_crawl_age)) %>%
# slice 1 obs per person
group_by(study_id_extraordinary) %>%
mutate(devfu_rolling_f2b_age = mean(devfu_rolling_f2b_age, na.rm = T),
devfu_rolling_b2f_age = mean(devfu_rolling_b2f_age, na.rm = T),
devfu_sit_age = mean(devfu_sit_age, na.rm = T),
devfu_coo_age = mean(devfu_coo_age, na.rm = T),
devfu_babble_age = mean(devfu_babble_age, na.rm = T),
devfu_singleword_age = mean(devfu_singleword_age, na.rm = T),
devfu_twoword_age = mean(devfu_twoword_age, na.rm = T),
devfu_sentences_age = mean(devfu_sentences_age, na.rm = T),
devfu_crawl_age = mean(devfu_crawl_age, na.rm = T),
devfu_cruise_age = mean(devfu_cruise_age, na.rm = T),
devfu_walk_age = mean(devfu_walk_age, na.rm = T),
devfu_run_age = mean(devfu_run_age, na.rm = T),
devfu_jump_age = mean(devfu_jump_age, na.rm = T)) %>%
ungroup() %>%
# get one obs per person
group_by(study_id_extraordinary) %>% slice(1) %>% ungroup() %>%
# pull only relevant columns
dplyr::select(study_id_extraordinary, sca_condition, devfu_rolling_f2b_age, devfu_rolling_b2f_age, devfu_sit_age,
devfu_coo_age, devfu_babble_age, devfu_singleword_age, devfu_twoword_age, devfu_sentences_age,
devfu_crawl_age, devfu_cruise_age, devfu_walk_age, devfu_run_age, devfu_jump_age) %>%
# Recode SCA condition
filter(sca_condition != 3) %>%
mutate(sca_condition = factor(sca_condition, levels = c(1, 2, 4), labels = c("XXY", "XYY", "XXYY")))
#### Case series figure
cs_fig <- hadh %>%
select(study_id_extraordinary, hdxfu_age, pmhfu_ftt_yn, pmhfu_ftt_age, pmhfu_torticollis_yn, pmhfu_torticollis_age,
rosfu_reflux_yn, rosfu_reflux_age, pmhfu_allergy_food_yn, pmhfu_allergy_food_age, pmhfu_allergy_environ_yn,
pmhfu_allergy_environ_age, pmhfu_eczema_yn, pmhfu_eczema_age, pmhfu_asthma_yn, pmhfu_asthma_age) %>%
# convert character ages to numeric
mutate(pmhfu_allergy_food_age = ifelse(pmhfu_allergy_food_age == "10 months", "10", pmhfu_allergy_food_age),
pmhfu_allergy_food_age = as.numeric(pmhfu_allergy_food_age),
pmhfu_allergy_environ_age = as.numeric(pmhfu_allergy_environ_age),
pmhfu_asthma_age = ifelse(pmhfu_asthma_age == "36 months", "36", pmhfu_asthma_age),
pmhfu_asthma_age = as.numeric(pmhfu_asthma_age), pmhfu_asthma_yn = as.numeric(pmhfu_asthma_yn)) %>%
# fix error codes
mutate(across(ends_with("_age"), ~ ifelse(.x > 400, NA, .x))) %>%
group_by(study_id_extraordinary) %>%
summarise(
# FTT
ftt_onset  = na_if(min(pmhfu_ftt_age, na.rm = TRUE), Inf),
ftt_offset = na_if(min(hdxfu_age[pmhfu_ftt_yn == 2], na.rm = TRUE), Inf),
# Torticollis
tort_onset  = na_if(min(pmhfu_torticollis_age, na.rm = TRUE), Inf),
tort_offset = na_if(min(hdxfu_age[pmhfu_torticollis_yn == 2], na.rm = TRUE), Inf),
# GE/Infant Reflux
ge_onset  = na_if(min(rosfu_reflux_age, na.rm = TRUE), Inf),
ge_offset = na_if(min(hdxfu_age[rosfu_reflux_yn == 2], na.rm = TRUE), Inf),
# Food allergies
fa_onset  = na_if(min(pmhfu_allergy_food_age, na.rm = TRUE), Inf),
fa_offset = na_if(min(hdxfu_age[pmhfu_allergy_food_yn == 2], na.rm = TRUE), Inf),
# Environmental allergies
ea_onset  = na_if(min(pmhfu_allergy_environ_age, na.rm = TRUE), Inf),
ea_offset = na_if(min(hdxfu_age[pmhfu_allergy_environ_yn == 2], na.rm = TRUE), Inf),
# Eczema
eczema_onset  = na_if(min(pmhfu_eczema_age, na.rm = TRUE), Inf),
eczema_offset = na_if(min(hdxfu_age[pmhfu_eczema_yn == 2], na.rm = TRUE), Inf),
# Asthma
asthma_onset  = na_if(min(pmhfu_asthma_age, na.rm = TRUE), Inf),
asthma_offset = na_if(min(hdxfu_age[pmhfu_asthma_yn == 2], na.rm = TRUE), Inf),
# Save max age per person
max_fu_age = max(hdxfu_age, na.rm = TRUE)   # store this once
) %>%
mutate(
ftt_offset  = ifelse(is.na(ftt_offset)  & !is.na(ftt_onset), max_fu_age, ftt_offset),
tort_offset = ifelse(is.na(tort_offset) & !is.na(tort_onset), max_fu_age, tort_offset),
ge_offset   = ifelse(is.na(ge_offset)   & !is.na(ge_onset),  max_fu_age, ge_offset),
fa_offset   = ifelse(is.na(fa_offset)   & !is.na(fa_onset),  max_fu_age, fa_offset),
ea_offset   = ifelse(is.na(ea_offset)   & !is.na(ea_onset),  max_fu_age, ea_offset),
eczema_offset   = ifelse(is.na(eczema_offset)   & !is.na(eczema_onset),  max_fu_age, eczema_offset),
asthma_offset   = ifelse(is.na(asthma_offset)   & !is.na(asthma_onset),  max_fu_age, asthma_offset)
) %>%
#select(-max_fu_age) %>%
ungroup() %>%
# pivot the data to create a column for outcome, onset, and offset
pivot_longer(!c(study_id_extraordinary, max_fu_age), names_to = "outcome", values_to = "age") %>%
mutate(timing = ifelse(grepl("_onset", outcome), "Onset", "Offset"),
outcome = case_when(grepl("ftt", outcome) ~ "Failure to Thrive",
grepl("tort", outcome) ~ "Torticollis",
grepl("ge", outcome) ~ "Gastroesophageal/Infantile Reflux",
grepl("fa", outcome) ~ "Food Allergies",
grepl("ea", outcome) ~ "Environmental Allergies",
grepl("eczema", outcome) ~ "Eczema", TRUE ~ "Reactive Airway Disease/Asthma")) %>%
pivot_wider(names_from = timing, values_from = age)
cs_fig[cs_fig == Inf] <- NA
cs_fig$sca_condition <- dems_clean$sca_condition[match(cs_fig$study_id_extraordinary, dems_clean$study_id_extraordinary)]
cs_fig_formatted <- cs_fig %>%
filter(sca_condition == "XXYY") %>%
arrange(max_fu_age) %>%
mutate(IDs = factor(study_id_extraordinary,
levels = unique(study_id_extraordinary),
labels = paste0("XXYY pt ", 1:15, "\n(Age ", ceiling(unique(max_fu_age)), " Months)")))
xrange <- diff(range(cs_fig_formatted$Onset, cs_fig_formatted$Offset, na.rm = TRUE))
nudge <- xrange * 0.01
library(ggplot2)
ggplot(cs_fig_formatted) +
geom_rect(
aes(xmin = max_fu_age + 1, xmax = Inf, ymin = -Inf, ymax = Inf),
fill = "gray90", alpha = 0.4
) +
# Segments without arrow (for those who finish before max follow-up)
geom_segment(
data = cs_fig_formatted %>% filter(Offset < max_fu_age),
aes(x = Onset + nudge, xend = Offset, y = outcome, yend = outcome)
) +
# Segments with arrow (when offset == max follow-up)
# geom_segment(
#   data = cs_fig_formatted %>% filter(Offset == max_fu_age),
#   aes(x = Onset + nudge, xend = Offset, y = outcome, yend = outcome),
#   arrow = arrow(length = unit(0.2, "cm"), type = "closed")
# ) +
geom_segment(
data = cs_fig_formatted %>% filter(Offset == max_fu_age),
aes(
x    = pmin(Onset, Offset, na.rm = TRUE),
xend = pmax(Onset, Offset, na.rm = TRUE),
y = outcome, yend = outcome
),
arrow = arrow(length = unit(0.2, "cm"), type = "closed")
) +
# Onset filled circle if offset != max follow-up
geom_point(
data = cs_fig_formatted %>% filter(Offset != Onset + 1),
aes(x = Onset, y = outcome),
size = 2
) +
# Offset points (only when before max follow-up)
geom_point(
data = cs_fig_formatted %>% filter(Offset < max_fu_age),
aes(x = Offset, y = outcome),
size = 2
) +
facet_wrap(~IDs, ncol = 5) +
xlab("Age (Months)") +
ylab("") +
theme_bw(base_size = 14) +
theme(strip.text = element_blank()) +
scale_x_continuous(breaks = seq(0, 100, 24))
