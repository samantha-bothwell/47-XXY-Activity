pct_low = 100 * (exp(beta_hat - 1.96*beta_se) - 1),
pct_high = 100 * (exp(beta_hat + 1.96*beta_se) - 1),
sind = seq(1, 1440, by = 1))
# Percent difference estimates
pct_ests <- data.frame(pct_hat = 100 * (exp(group_hat) - 1),
pct_low = 100 * (exp(group_hat - 1.96*group_se) - 1),
pct_high = 100 * (exp(group_hat + 1.96*group_se) - 1),
sind = seq(1, 1440, by = 1))
ggplot(pct_ests, aes(x = sind, y = pct_hat)) +
geom_hline(yintercept = 1, color = "black", linetype = "dashed", size = 0.9) +
geom_ribbon(aes(x = sind, ymin = pct_low, ymax = pct_high),
fill = "blue", alpha = 0.2)
# Percent difference plot
ggplot(pct_ests, aes(x = sind, y = pct_hat)) +
geom_hline(yintercept = 1, color = "black", linetype = "dashed", size = 0.9) +
geom_ribbon(aes(x = sind, ymin = pct_low, ymax = pct_high),
fill = "blue", alpha = 0.2) +
geom_line(size = 1)  +
ylab("Percent Difference in Expected METs per Minute\n(KS Cases vs Non-KS Controls)") +
ggtitle("Functional Percent Difference METs per Minute") + theme_bw() +
scale_x_continuous(breaks = c(0, 182, 362, 542, 722, 902, 1082, 1262, 1442),
labels = c("Midnight", "3 am", "6 am", "9 am", "Noon", "3 pm", "6 pm",
"9 pm", "Midnight")) +
xlab("") + theme(text = element_text(size = 16), plot.title = element_text(hjust = 0.5))
