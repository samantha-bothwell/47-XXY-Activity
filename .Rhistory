pmhfu_heart_age = as.numeric(pmhfu_heart_age), pmhfu_vpi_age = as.numeric(pmhfu_vpi_age),
pmhfu_asthma_age = ifelse(pmhfu_asthma_age == "around 2 ", "2", pmhfu_asthma_age),
