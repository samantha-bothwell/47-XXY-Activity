# Linear Regression
lm_stats <- dems_sleep %>%
group_by(group) %>%
do(tidy(lm(sleep_ped_t ~ mean_mets, data = .))) %>%
filter(term == "mean_mets") %>%
mutate(label = paste0(group, "\n",
"β = ", round(estimate, 2), "\n",
ifelse(p.value < 0.001, "p < 0.001", paste0("p = ", round(p.value, 3)))))
library(dplyr)
library(broom)
## Correlation plot
# Linear Regression
lm_stats <- dems_sleep %>%
group_by(group) %>%
do(tidy(lm(sleep_ped_t ~ mean_mets, data = .))) %>%
filter(term == "mean_mets") %>%
mutate(label = paste0(group, "\n",
"β = ", round(estimate, 2), "\n",
ifelse(p.value < 0.001, "p < 0.001", paste0("p = ", round(p.value, 3)))))
# Positioning
x_max <- max(dems_sleep$mean_mets, na.rm = TRUE)
y_max <- max(dems_sleep$sleep_ped_t, na.rm = TRUE)
lm_stats <- lm_stats %>%
arrange(group) %>%
mutate(x = x_max * 0.70, y = y_max - (row_number() - 1) * 5)
# Plot
ggplot(dems_sleep, aes(x = mean_mets, sleep_ped_t, color = group)) +
geom_point(size = 3) + geom_smooth(method = "lm") +
theme_bw() +
theme(text = element_text(size = 20),
legend.position = "bottom") +
scale_color_manual(values = c("#369dd9", "#6D6D6D")) +
labs(color = "", x = "Average Daily METs", y = "PROMIS Pediatric \nSleep T-Score") +
geom_label(data = lm_stats, aes(x = x, y = y, label = label, color = group),
inherit.aes = FALSE, hjust = 0, size = 5, fill = "white", label.size = 0.4)
View(lm_stats)
