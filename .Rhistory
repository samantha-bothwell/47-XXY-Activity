# Teen Survey data
teen <- read.csv("/Volumes/Shared/Shared Projects/Bothwell/Peds ENDO/Shomaker/BREATHE/Data/202649BREATHETeenSur_DATA_2025-02-12_1116.csv")
#########################################################################
## Clean TASA data -- We are interested in the baseline data
#########################################################################
## Select TASA data
teen_tasa <- teen %>%
dplyr::select(id, redcap_event_name, contains("tasaq")) %>%
# Filter to baseline data
filter(redcap_event_name == "week_1_arm_1") %>%
# filter out missing data
filter(!is.na(tasaq1))
# Add ID, sex, and baseline age
teen_tasa$age <- redcap_rand$age[match(teen_tasa$id, redcap_rand$study_id)]
teen_tasa$sex <- redcap_rand$sex[match(teen_tasa$id, redcap_rand$study_id)]
View(teen_tasa)
## Sum columns
teen_tasa <- teen_tasa %>%
mutate(TASA_Sum = select(., tasaq1:tasaq12) %>% rowSums())
rm(list = ls())
