sumdata_agg <- read_csv(here::here("data-clean", "Aggregated1min_cleaned.csv")) %>%
mutate(ID = as.character(ID))
## Activity fpca
sumdata_agg_wide <- sumdata_agg %>%
dplyr::select(ID, index, avg_met_minute) %>%
pivot_wider(names_from = "index", values_from = "avg_met_minute")
sumdata_agg_wide[-1,]
sumdata_agg_wide[,-1]
result <- fpca.face(Y = sumdata_agg_wide[,-1])
result <- fpca.face(Y = as.matrix(sumdata_agg_wide[,-1]))
act_scores <- result$scores
library(refund.shiny)
plot_shiny(result)
act_scores <- result$scores[,1:6]
act_scores <- data.frame(result$scores[,1:6])
act_scores$ID <- sumdata_agg_wide$ID
full_data$act_PCA1 <- act_scores$X1[match(full_data$pid, act_scores$ID)]
full_data$act_PCA2 <- act_scores$X2[match(full_data$pid, act_scores$ID)]
full_data$act_PCA3 <- act_scores$X3[match(full_data$pid, act_scores$ID)]
full_data$act_PCA4 <- act_scores$X4[match(full_data$pid, act_scores$ID)]
full_data$act_PCA5 <- act_scores$X5[match(full_data$pid, act_scores$ID)]
full_data$act_PCA6 <- act_scores$X6[match(full_data$pid, act_scores$ID)]
## Sleep fpca
sumsleep_1min_agg_wide <- sumsleep_1min_agg %>%
dplyr::select(ID, index, mean_interp) %>%
pivot_wider(names_from = "index", values_from = "mean_interp")
## Sleep fpca
sumsleep_1min_agg_wide <- sumsleep_1min_agg %>%
dplyr::select(ID, t_norm, mean_interp) %>%
pivot_wider(names_from = "index", values_from = "mean_interp")
