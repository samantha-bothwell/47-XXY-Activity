### Summarize Avg Daily METs
avg_mets <- sumdata_day %>%
group_by(date, ID, group) %>%
summarise(mean_mets = mean(met_minute, na.rm = T)) %>%
ungroup() %>% group_by(ID, group) %>%
summarise(mean_mets = mean(mean_mets, na.rm = T))
### Self-Report vs Actual
