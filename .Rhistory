xlab("") + ylab("PROMIS Parent Proxy T-Score") +
scale_y_continuous(limits = c(35, 75), breaks = seq(40, 70, by = 10)) +
annotate("text", x = 1.5, y = 75, label = pp_pval, size = 5)
## Organize plots
