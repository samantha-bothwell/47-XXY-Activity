## Libraries
library(readr)
library(ggplot2)
library(dplyr)
library(tidyr)
library(gridExtra)
library(broom)
## Load data
full_data <- read_csv(here::here("data-raw", "identifiable", "LTE_FullDATA_03172026.csv"))
## Load data
full_data <- read_csv(here::here("data-raw", "LTE_FullDATA_03172026.csv"))
names(full_data)
## Subset nutrition
nutrition <- full_data %>%
# select variables of interest
dplyr::select(pid, redcap_event_name, fats, carbs, protein, calories, tee, cal_percent_tee)
rm(list = ls())
## Libraries
library(tidyverse)
library(ggsci)
library(ggplot2)
## Data
insights <- read.csv("/Volumes/Shared/Shared Projects/Bothwell/Peds ENDO/SCA Studies/Carl - Audiology/Data/INSIGHTSRegistry-AudiologyData_DATA_2024-08-30_1058.csv")
basicinfo <- read.csv("/Volumes/Shared/Shared Projects/Bothwell/Peds ENDO/SCA Studies/Carl - Audiology/Data/InsighTS_BasicInformation.csv")
coreelements <- read.csv("/Volumes/Shared/Shared Projects/Bothwell/Peds ENDO/SCA Studies/Carl - Audiology/Data/CoreElements_DATA_2024-10-21_1439.csv")
## Clean the data
insights_clean <- insights %>%
## Pull out the variables we care about
dplyr::select(record_id, audi_visitdate, dob_guid, audi_fu_age, audio_resultsleft_fu, audio_resultsright_fu) %>%
## Calculate age
group_by(record_id) %>%
mutate(dob_guid = max(as.Date(dob_guid, format = "%Y-%m-%d"), na.rm = T)) %>%
ungroup() %>%
mutate(audi_fu_age = as.numeric(as.Date(audi_visitdate, format = "%Y-%m-%d") - dob_guid)/365,
audi_fu_age = ifelse(audi_fu_age == -Inf, NA, audi_fu_age)) %>%
## filter out missing or incorrect data
filter(!is.na(audi_fu_age)) %>%
filter(audi_fu_age > 0) %>%
filter(!(is.na(audio_resultsleft_fu) & is.na(audio_resultsright_fu))) %>%
## Code the audio results
mutate(audio_resultsleft_fu = factor(audio_resultsleft_fu, levels = c(1:6), labels = c("Normal Hearing", "Conductive Hearing Loss",
"Sensorineural Hearing Loss", "Mixed Hearing Loss",
"Inconclusive", "Unspecified")),
audio_resultsright_fu = factor(audio_resultsright_fu, levels = c(1:6), labels = c("Normal Hearing", "Conductive Hearing Loss",
"Sensorineural Hearing Loss", "Mixed Hearing Loss",
"Inconclusive", "Unspecified"))) %>%
## Pivot the data longer
dplyr::select(-c(audi_visitdate, dob_guid)) %>%
pivot_longer(!c(record_id, audi_fu_age), names_to = "ear", values_to = "hearing_loss") %>%
## recode ear
mutate(ear = ifelse(ear == "audio_resultsleft_fu", "Left", "Right")) %>%
## Passed Newborn Hearing
#mutate(neo_nhbs_inq = ifelse(neo_nhbs_inq == 1, "Yes", "No")) %>%
# Filter out inconclusive findings
filter(hearing_loss != "Inconclusive") %>%
# Get first age of hearing loss
# filter(!(hearing_loss %in% c("Normal Hearing", "Inconclusive"))) %>%
group_by(record_id, ear, hearing_loss) %>%
filter(audi_fu_age == min(audi_fu_age, na.rm = T)) %>%
ungroup() %>%
filter(!is.na(hearing_loss))
insights$data_entry_audi
View(insights)
rm(list = ls())
# Libaries
library(tidyverse)
library(logistf)
library(gtsummary)
library(zscorer)
library(kableExtra)
## Data (You can go to Import Dataset > From text (readr) to browse for your dataset)
ts <- read.csv("/Volumes/Shared/Shared Projects/Bothwell/Peds ENDO/SCA Studies/Keller - TS Perinatal History/Data/INSIGHTSRegistry-AlyssaKellerProject_DATA_2026-02-11_1147.csv")
ts_dems <- read.csv("/Volumes/Shared/Shared Projects/Bothwell/Peds ENDO/SCA Studies/Keller - TS Perinatal History/Data/INSIGHTS_Dems_2026-02-12_1032.csv") # Basic Info-Study Staff
ts_peri <- read.csv("/Volumes/Shared/Shared Projects/Bothwell/Peds ENDO/SCA Studies/Keller - TS Perinatal History/Data/INSIGHTS_Perinatal_2026-02-12_1033.csv")
## Clean data
ts_clean <- ts %>%
# Karli says exclude 01-0146 on Feb 9th, 2026 in teams chat
filter(!(record_id %in% c("01-0146", "01-0199", "03-0085"))) %>%
# filter out other genetic conditions as exclusion criteria
filter(!(othergeneticdiag %in% c("alagille syndrme", "Trisomy 9"))) %>%
# Remove repeating
filter(redcap_event_name == "core_elements_clin_arm_1") %>%
# fix prenatal testing reason
group_by(record_id) %>%
mutate(diag_reason_prenatal = max(diag_reason_prenatal, na.rm = T),
neonatal_cardsstru = max(neonatal_cardsstru, na.rm = T),
neonatal_cardsrhy = max(neonatal_cardsrhy, na.rm = T),
paternal_age = max(paternal_age, na.rm = T), paternal_age = ifelse(paternal_age == -Inf, NA, paternal_age)) %>%
ungroup() %>%
# categorize incidental
mutate(incidental_prenatal = ifelse(diag_reason_prenatal %in% c(1, 2, 4), "Yes", "No")) %>%
# Require genetic report
filter(genetic_report_avail == 1 | report_unavailable == 1) %>%
# # remove some columns
dplyr::select(where(~ mean(is.na(.)) < 0.5) | paternal_age) %>%
dplyr::select(where(~ mean(. == "", na.rm = T) < 0.5)) %>%
dplyr::select(-c(karyotype_freetext)) %>%
# get rid of -Inf
mutate(diag_reason_prenatal = ifelse(diag_reason_prenatal == -Inf, 0, diag_reason_prenatal),
neonatal_cardsstru = ifelse(neonatal_cardsstru == -Inf, 0, neonatal_cardsstru),
neonatal_cardsrhy = ifelse(neonatal_cardsrhy == -Inf, 0, neonatal_cardsrhy)) %>%
# Assign karyotype
mutate(karyotype_category_calc = ifelse(record_id == "05-0061", 1, karyotype_category_calc), # Redcap issue that isn't easy to solve (per Alexa on 10/7/25 in teams)
karyotype_category_calc = ifelse(is.na(karyotype_category_calc), 555, karyotype_category_calc),
karyotype_category_calc_num = karyotype_category_calc,
karyotype_category_calc = factor(karyotype_category_calc, levels = c(1:9, 555),
labels = c("45,X", "45,X/46,XX", "45,X/46,XY",
"45,X/47,XXX", "Ring X", "Isochromosome",
"Other", "Other", "Other", "Other")),
karyotype_category_calc = relevel(karyotype_category_calc, ref = "45,X"))
table(ts_clean$karyotype_category_calc)
## Make sure dems has diagnostic timing, adoption, and karyotype
ts_dems$diag_timing <- ts$diag[match(ts_dems$record_id, ts$record_id)]
ts_dems$diag_age <- ts$diag_age[match(ts_dems$record_id, ts$record_id)]
ts_dems$adopted <- ts$adopted[match(ts_dems$record_id, ts$record_id)]
ts_dems$karyotype_category_calc <- ts_clean$karyotype_category_calc[match(ts_dems$record_id, ts_clean$record_id)]
ts_dems$karyotype_category_calc_num <- ts_clean$karyotype_category_calc_num[match(ts_dems$record_id, ts_clean$record_id)]
ts_dems$age_at_diagnosis <- ts$diag_age[match(ts_dems$record_id, ts$record_id)]
ts_dems$maternal_age <- ts$maternal_age[match(ts_dems$record_id, ts$record_id)]
ts_dems$paternal_age <- ts$paternal_age[match(ts_dems$record_id, ts$record_id)]
ts_dems$mult_gestation <- ts$mult_gestation[match(ts_dems$record_id, ts$record_id)]
ts_dems$incidental <- ts$diag_reason_postnatal___7[match(ts_dems$record_id, ts$record_id)]
ts_dems$incidental_prenatal <- ts_clean$incidental_prenatal[match(ts_dems$record_id, ts_clean$record_id)]
## Clean dems data
dems_clean <- ts_dems %>%
# filter to enrollment
filter(redcap_event_name == "enrollment_arm_1") %>%
# code race/ethnicity
mutate(race_ethnicity = case_when(race_eth_new___4 == 1 ~ "Hispanic/Latinx",
race_eth_new___1 + race_eth_new___2 + race_eth_new___3 + race_eth_new___5 +
race_eth_new___6 + race_eth_new___7 > 1 ~ "More than one race",
race_eth_new___7 == 1 ~ "White Non-Hispanic",
race_eth_new___1 == 1 ~ "Other", #"American Indian or Alaska Native",
race_eth_new___2 == 1 ~ "Asian",
race_eth_new___3 == 1 ~ "Black Non-Hispanic",
race_eth_new___5 == 1 ~ "Other", #"Middle Eastern or North African",
race_eth_new___6 == 1 ~ "Other", #"Native Hawaiian or Pacific Islander",
.default = "Unknown")) %>%
# code year of birth
mutate(yob = as.numeric(substr(dob_guid, 1, 4))) %>%
mutate(yob = ifelse(yob < 2000, "Prior to 2000", ifelse(yob <= 2004, "2000 - 2004",
ifelse(yob <= 2009, "2005 - 2009", ifelse(yob <= 2014, "2010 - 2014",
ifelse(yob <= 2019, "2015 - 2019", "2020 and Later")))))) %>%
# code insurance
mutate(payor_at_enrollment = factor(payor_at_enrollment, levels = c(1:6, 555),
labels = c("Medicaid/Medicare", "Private", "Military", "Charity Care", "2 or More", "None",
"Other"))) %>%
# code diagnosis timing
mutate(diag_timing = factor(diag_timing, levels = c(1, 2, 3), labels = c("Prenatal", "Postnatal", "Prenatal"))) %>%
# code adoption
mutate(adopted = ifelse(adopted == 1, "Yes", "No")) %>%
# code clinic
mutate(site_enroll = factor(site_enroll, levels = c(1:16, 555),
labels = c("CHCO/Denver", "CHOP", "Children's National, DC",
"Lurie Children's Chicago", "UNC at Chapel Hill",
"University of Texas Health Science Center at Houston",
"University of Kansas Medical Center",
"Cincinnati Children's Hospital Medical Center",
"Seattle Children's", "University of Iowa",
"University of California San Diego",
"Nationwide Children's Hospital", "John Hopkins All Children's",
"University of Pennsylvania", "Medical College of Wisconsin",
"Emory University", "Online"))) %>%
# code multiple gestation
mutate(mult_gestation = ifelse(mult_gestation %in% c(2, 3, 4), "Yes", "No"),
incidental = ifelse(incidental == 1, "Yes", "No")) %>%
# Get the number of people diagnosed within 3 months postnatally
mutate(within3mo = ifelse(age_at_diagnosis <= 3, "Yes", "No")) %>%
# select only the variables we care about
dplyr::select(record_id, karyotype_category_calc, yob, site_enroll, race_ethnicity, payor_at_enrollment,
diag_timing, adopted, within3mo, age_at_enroll, karyotype_category_calc_num, maternal_age, paternal_age,
mult_gestation, incidental, diag_age, incidental_prenatal) %>%
# filter out anyone missing a karyotype
filter(!is.na(karyotype_category_calc))
ts_clean$site <- dems_clean$site_enroll[match(ts_clean$record_id, dems_clean$record_id)]
ts_clean$missing_count <- rowSums(is.na(ts_clean))
summary(glm(missing_count ~ site, data = ts_clean, family = "poisson"))
## Split into perinatal and neonatal datasets
## Clean perinatal data
perinatal <- ts_peri %>%
filter(redcap_event_name == "core_elements_clin_arm_1") %>%
dplyr::select(record_id, redcap_event_name, contains("preg_comp_fetus"), mult_gestation) %>%
# filter out missing data
filter(rowSums(select(., starts_with("preg_comp_fetus___"))) != 0) %>%
# combine Oligohydramnios and Polyhydramnios
mutate(oligo_poly = ifelse(preg_comp_fetus___5 == 1 | preg_comp_fetus___6 == 1, 1, 0),
mult_gestation = ifelse(mult_gestation %in% c(2, 3, 4), "Yes", "No")) %>%
# rename variables
rename(cystic_hygroma = preg_comp_fetus___1, iugr = preg_comp_fetus___2,
oligo = preg_comp_fetus___5, polyhy = preg_comp_fetus___6,
cardiac_malformation = preg_comp_fetus___3, renal_anomaly = preg_comp_fetus___4,
breech = preg_comp_fetus___7, soft_ultrasound = preg_comp_fetus___8,
fetal_arrythmia = preg_comp_fetus___11) %>%
# convert 0/1 to no/yes
mutate(across(-c(record_id, redcap_event_name),
~ case_when(. == 1 ~ "Yes", . == 0 ~ "No", TRUE ~ as.character(.))))
prenatal <- ts_clean %>%
filter(rowSums(select(., starts_with("preg_comp_mat___"))) != 0) %>%
# select variables of interest
dplyr::select(record_id, redcap_event_name, karyotype_category_calc, contains("preg_comp_mat"), diag,
contains("preg_comp_fetus")) %>%
# code diag
mutate(diag = factor(diag, levels = c(1, 2, 3), labels = c("Prenatal", "Postnatal", "Prenatal"))) %>%
mutate(across(contains("preg_comp_mat"), ~ifelse(.x == 1, "Yes", "No"))) %>%
mutate(across(contains("preg_comp_fetus"), ~ifelse(.x == 1, "Yes", "No")))
ts_peri_filt <- ts_peri %>% filter(redcap_event_name == "core_elements_clin_arm_1")
ts_clean$gest_age <- ts_peri_filt$gest_age[match(ts_clean$record_id, ts_peri_filt$record_id)]
ts_clean$birthweight <- ts_peri_filt$birthweight[match(ts_clean$record_id, ts_peri_filt$record_id)]
ts_clean$birth_length <- ts_peri_filt$birth_length[match(ts_clean$record_id, ts_peri_filt$record_id)]
birth <- ts_clean %>%
mutate(gest_age = as.numeric(gest_age), birthweight = as.numeric(birthweight),
birth_length = as.numeric(birth_length)) %>%
mutate(gest_age_m = ifelse(is.na(gest_age_m), gest_age, gest_age_m),
birthweight_m = ifelse(is.na(birthweight_m), birthweight, birthweight_m),
birth_length_m = ifelse(is.na(birth_length_m), birth_length, birth_length_m)) %>%
dplyr::select(record_id, redcap_event_name, karyotype_category_calc, mult_gestation, gest_age, gest_age_m,
birthweight_m, birth_length_m, maternal_age, paternal_age, delivery, diag_reason_prenatal,
preg_comp_fetus___9, preg_comp_fetus___10) %>%
mutate(delivery = factor(delivery, levels = c(1, 2), labels = c("Vaginal", "C-section")),
preterm = ifelse(gest_age_m < 37, "Yes", "No"),
afp = ifelse(preg_comp_fetus___9 == 1, "Yes", "No"),
meconium_aspiration = ifelse(preg_comp_fetus___10 == 1, "Yes", "No"),
mult_gestation = ifelse(mult_gestation %in% c(2, 3, 4), "Yes", "No")) %>%
filter(!(is.na(maternal_age) & is.na(gest_age_m) & is.na(birthweight_m) & is.na(birth_length_m))) %>%
mutate(sex = 2, age = 0)
birth <- addWGSR(data = birth, sex = "sex", firstPart = "birthweight_m", secondPart = "age", index = "wfa")
birth <- addWGSR(data = birth, sex = "sex", firstPart = "birth_length_m", secondPart = "age", index = "lfa")
birth$sga <- ifelse(birth$wfaz < qnorm(0.1) | birth$lfaz < qnorm(0.1), "Yes", "No")
neonatal <- ts_clean %>%
dplyr::select(record_id, redcap_event_name, karyotype_category_calc, contains("neonatal")) %>%
filter(!(is.na(neonatal_hypogylcemia) & is.na(neonatal_resp) & is.na(neonatal_feed) & is.na(neonatal_cardio) &
is.na(neonatal_hyper))) %>%
dplyr::select(-neonatal_desc) %>%
# assume 0 for NAs
mutate(across(c(starts_with("neonatal"), -neonatal_nbhs), ~ replace_na(., 0))) %>%
# code no complications
mutate(neonatal_no_comps = ifelse(neonatal_nbhs == 0 | neonatal_nicu == 1 | neonatal_hypogylcemia == 1 |
neonatal_resp == 1 | neonatal_feed == 1 | neonatal_cardio == 1 |
neonatal_hyper == 1 | neonatal_lymphedema == 1 | neonatal_sepsis == 1 |
neonatal_chylo == 1 | neonatal_anesthesia == 1 | neonatal_asphyxia == 1 |
neonatal_renal == 1 | neonatal_bloodcond == 1 | neonatal_seizure == 1 |
neonatal_other == 1 | neonatal_cardsstru == 1 | neonatal_cardsrhy == 1,
0, 1)) %>%
# recategorize
mutate(across(starts_with("neonatal"), ~ factor(., levels = c(0, 1), labels = c("No", "Yes"))))
## filter dems dataset
dems_clean <- dems_clean %>% filter(record_id %in% unique(c(perinatal$record_id, prenatal$record_id,
neonatal$record_id, birth$record_id)))
perinatal <- perinatal %>% filter(record_id %in% dems_clean$record_id)
prenatal <- prenatal %>% filter(record_id %in% dems_clean$record_id)
birth <- birth %>% filter(record_id %in% dems_clean$record_id)
neonatal <- neonatal %>% filter(record_id %in% dems_clean$record_id)
ts_clean <- ts_clean %>% filter(record_id %in% dems_clean$record_id)
###### Organize dataset and confirm numbers align
dems_clean$birth_data_present <- ifelse(dems_clean$record_id %in% birth$record_id, "Yes", "No")
dems_clean$prenatal_data_present <- ifelse(dems_clean$record_id %in% prenatal$record_id, "Yes", "No")
dems_clean$neonatal_data_present <- ifelse(dems_clean$record_id %in% neonatal$record_id, "Yes", "No")
full_data <- dems_clean %>%
dplyr::select(-yob, -mult_gestation, -incidental, -within3mo, -karyotype_category_calc_num,
-maternal_age, -paternal_age) %>%
full_join(
birth %>%
dplyr::select(-redcap_event_name, -karyotype_category_calc, -sex, -age, -preg_comp_fetus___9,
-preg_comp_fetus___10, -gest_age),
by = "record_id"
) %>%
full_join(
prenatal %>%
dplyr::select(-redcap_event_name, -karyotype_category_calc),
by = "record_id"
) %>%
full_join(
neonatal %>%
dplyr::select(-redcap_event_name, -karyotype_category_calc),
by = "record_id"
) %>%
#mutate(record_id = 1:n()) %>%
mutate(diag_age = round(diag_age, 1)) %>%
rename(prenatal_mat_comp_none = preg_comp_mat___0,
prenatal_mat_comp_gest_diab = preg_comp_mat___1,
prenatal_mat_comp_hyperten_preeclamp = preg_comp_mat___2,
prenatal_mat_comp_infection = preg_comp_mat___3,
prenatal_mat_comp_premat_labor = preg_comp_mat___4,
prenatal_mat_comp_alc_drug = preg_comp_mat___5,
prenatal_mat_comp_no_late_care = preg_comp_mat___6,
prenatal_mat_comp_anemia = preg_comp_mat___7,
prenatal_mat_comp_plac_uter_concern = preg_comp_mat___9,
prenatal_mat_comp_med_use = preg_comp_mat___10,
prenatal_mat_comp_hyperemesis = preg_comp_mat___11,
prenatal_mat_comp_hypothyroid = preg_comp_mat___12,
prenatal_mat_comp_other = preg_comp_mat___555,
prenatal_fetus_comp_none = preg_comp_fetus___0,
prenatal_fetus_comp_hygroma = preg_comp_fetus___1,
prenatal_fetus_comp_iugr = preg_comp_fetus___2,
prenatal_fetus_comp_heart_malform = preg_comp_fetus___3,
prenatal_fetus_comp_renal_anomaly = preg_comp_fetus___4,
prenatal_fetus_comp_oligo = preg_comp_fetus___5,
prenatal_fetus_comp_polyhy = preg_comp_fetus___6,
prenatal_fetus_comp_breech = preg_comp_fetus___7,
prenatal_fetus_comp_soft_ultrasound = preg_comp_fetus___8,
prenatal_fetus_comp_struc_malform = preg_comp_fetus___9,
prenatal_fetus_comp_meconium = preg_comp_fetus___10,
prenatal_fetus_comp_arrhythmia = preg_comp_fetus___11,
prenatal_fetus_comp_other = preg_comp_fetus___555,
small_gest_age = sga, birthweight_z = wfaz, birthlength_z = lfaz,
abnorm_fetal_pres = afp) %>%
mutate(neonatal_cardsstru = as.character(neonatal_cardsstru),
neonatal_cardsstru = ifelse(prenatal_fetus_comp_heart_malform == "Yes", "No", neonatal_cardsstru)) %>%
filter(!(birth_data_present == "No" & prenatal_data_present == "No" & neonatal_data_present == "No"))
dems_clean <- dems_clean %>% filter(record_id %in% full_data$record_id)
full_data$record_id <- 1:length(full_data$record_id)
names(full_data)
cardiac <- full_data %>% dplyr::select(record_id, prenatal_fetus_comp_heart_malform, neonatal_cardsstru)
View(cardiac)
