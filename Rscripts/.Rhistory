#######################################
# Post Op Pain Data Cleaning
#
# PIs : Norman Friedman
#       Luka Bahra
#
# Analyst : Samantha Bothwell
#
# Date Modified : October 3rd, 2024
#######################################
### FLAGS
#   1. There are duplicate entries in the full dataset that need to be checked.
#   2. The consolidated dataset that I have has fewer MRNs (N = 12371), after filter to only IDs in the full dataset (N = 12524).
#
rm(list = ls())
## Libraries
library(tidyverse)
library(readxl)
library(janitor)
## Datasets
meds <- read_excel("~/Documents/Friedman - Post Op Pain/Data/19-2031 POP TA Raw Data Matched.xlsx", sheet = 1)
all_dat <- read_excel("~/Documents/Friedman - Post Op Pain/Data/19-2031 POP TA Raw Data Matched.xlsx", sheet = 2)
dems <- read_excel("~/Documents/Friedman - Post Op Pain/Data/19-2031 POP TA Report Consolidated.xlsx")
###############################
## Clean all data for analysis
###############################
## Remove duplicate rows in all_dat
# Pull out duplicates to send to Luka
all_dat_dups <- all_dat %>% group_by(mrn) %>% filter(n() > 1)
write.csv(all_dat_dups, "~/Documents/Friedman - Post Op Pain/Data/19-2031 POP TA DUPLICATES Data Matched.xlsx")
# FOR NOW - Remove duplicates
all_dat <- all_dat %>% group_by(mrn) %>% slice(1); length(unique(all_dat$mrn))
# Restrict to only data from 2020 and after
all_dat$year <- as.numeric(substr(all_dat$anesth_start, 1, 4))
all_dat <- all_dat[all_dat$year >= 2020, ]
# Make sure we have data on procedure
all_dat <- all_dat %>% filter(!is.na(Procedure))
## Filter datasets to only IDs in the all_dat dataset
meds <- meds %>% filter(patient_mrn %in% all_dat$mrn); length(unique(meds$patient_mrn))
dems <- dems %>% filter(MRN %in% all_dat$mrn); length(unique(dems$MRN))
## Add surgery stop time and PACU arrival time to the medications dataset
meds$surg_stop <- all_dat$surg_stop[match(meds$patient_mrn, all_dat$mrn)]
meds$pacu_arrv_time <- all_dat$pacu_arrv_time[match(meds$patient_mrn, all_dat$mrn)]
meds$phase2in <- all_dat$phase2in[match(meds$patient_mrn, all_dat$mrn)]
meds$floor_arrv_time <- all_dat$floor_arrv_time[match(meds$patient_mrn, all_dat$mrn)]
meds$discharge_date <- all_dat$discharge_date[match(meds$patient_mrn, all_dat$mrn)]
meds$pacu_end <- as.POSIXct(ifelse(!is.na(meds$phase2in), meds$phase2in, meds$floor_arrv_time))
meds$or_out <- all_dat$or_out[match(meds$patient_mrn, all_dat$mrn)]
meds$unplannedcall <- all_dat$unplancalldate[match(meds$patient_mrn, all_dat$mrn)]
meds$unplannedcall <- ifelse(is.na(meds$unplannedcall), "No", "Yes")
meds$post_op_opioid <- dems$`Postop Opioid Prescription`[match(meds$patient_mrn, dems$MRN)]
meds$post_op_aspirin <- dems$`Postop NSAID Prescription`[match(meds$patient_mrn, dems$MRN)]
meds$post_op_acetaminophen <- dems$`Postop Acetaminophen Prescription`[match(meds$patient_mrn, dems$MRN)]
## Assign indicator of post surgery and PACU
meds$post_surgery <- ifelse(meds$med_taken_time > meds$surg_stop, "Yes", "No")
meds$in_PACU_or_later <- ifelse(meds$med_taken_time > meds$pacu_arrv_time, "Yes", "No")
meds$in_PACU <- ifelse(meds$med_taken_time >= meds$pacu_arrv_time & meds$med_taken_time <= meds$pacu_end, "Yes", "No")
meds$in_OR <- ifelse(meds$med_taken_time > meds$surg_stop & meds$med_taken_time <= meds$or_out, "Yes", "No")
meds$on_floor <- ifelse(meds$med_taken_time > meds$floor_arrv_time & meds$med_taken_time <= meds$discharge_date, "Yes", "No")
## Assign groupings
# Intra/Extra Capsular
meds$intra_extra <- dems$`Tonsillectomy Surgical Technique`[match(meds$patient_mrn, dems$MRN)]
meds$intra_extra <- sapply(strsplit(meds$intra_extra," - "), `[`, 1)
dems$intra_extra <- sapply(strsplit(dems$`Tonsillectomy Surgical Technique`," - "), `[`, 1)
# Discharge
dems$discharge_group <- ifelse(as.Date(dems$`Admission Date`) == as.Date(dems$`Discharge Date`),
"Same Day Discharge",
ifelse(as.Date(dems$`Discharge Date`) > as.Date(dems$`Admission Date`),
"Stayed Over Night", "ERROR"))
meds$discharge_group <- dems$discharge_group[match(meds$patient_mrn, dems$MRN)]
## Categorize reasons for ED and unplanned phone calls
# ED 2 Day
dems$ed_2day_reason <- ifelse(grepl("BLEED|HEMOPTYSIS", dems$`ED Visit - 2 Days Reason`), "Oral Bleeding",
ifelse(grepl("RESPIRATORY|COUGH|BREATHING", dems$`ED Visit - 2 Days Reason`), "Respiratory",
ifelse(grepl("DENTAL|MOUTH|DEHYDRATION|INTAKE|EENT THROAT", dems$`ED Visit - 2 Days Reason`), "Pain/Oral Intake/Dehydration",
ifelse(grepl("MEDICATION|ABDOMINAL|CONSTIPATION|NAUSEA|VOMITING|ALLERGIC REACTION", dems$`ED Visit - 2 Days Reason`), "Medication Related",
ifelse(grepl("EPISTAXIS", dems$`ED Visit - 2 Days Reason`), "Epistaxis",
ifelse(grepl("FEVER", dems$`ED Visit - 2 Days Reason`), "Fever",
ifelse(grepl("EARACHE", dems$`ED Visit - 2 Days Reason`), "Earache",
ifelse(grepl("NECK PAIN", dems$`ED Visit - 2 Days Reason`), "Neck Pain",
ifelse(grepl("HEADACHE", dems$`ED Visit - 2 Days Reason`), "Headache",
ifelse(grepl("EENT|NASAL CONGESTION", dems$`ED Visit - 2 Days Reason`), "EENT Non-Specified",
ifelse(grepl("DOG BITE|URIN|DIARRHEA|BRAIN|CHEST|FUSSY|BURN|FEEDING TUBE|FOREIGN|SYNCOPE|SWELLING", dems$`ED Visit - 2 Days Reason`),
"Non-ENT Related",
ifelse(grepl("OTHER", dems$`ED Visit - 2 Days Reason`), "Other", "Other"))))))))))))
dems$ed_2day_reason <- ifelse(is.na(dems$`ED Visit - 2 Days Reason`), NA, dems$ed_2day_reason)
# ED 15 Day
dems$ed_15day_reason <- ifelse(grepl("BLEED|HEMOPTYSIS", dems$`ED Visit - 15 Days Reason`), "Oral Bleeding",
ifelse(grepl("RESPIRATORY|COUGH|BREATHING", dems$`ED Visit - 15 Days Reason`), "Respiratory",
ifelse(grepl("DENTAL|MOUTH|DEHYDRATION|INTAKE|EENT THROAT", dems$`ED Visit - 15 Days Reason`), "Pain/Oral Intake/Dehydration",
ifelse(grepl("MEDICATION|ABDOMINAL|CONSTIPATION|NAUSEA|VOMITING|ALLERGIC REACTION", dems$`ED Visit - 15 Days Reason`), "Medication Related",
ifelse(grepl("EPISTAXIS", dems$`ED Visit - 15 Days Reason`), "Epistaxis",
ifelse(grepl("FEVER", dems$`ED Visit - 15 Days Reason`), "Fever",
ifelse(grepl("EARACHE", dems$`ED Visit - 15 Days Reason`), "Earache",
ifelse(grepl("NECK PAIN", dems$`ED Visit - 15 Days Reason`), "Neck Pain",
ifelse(grepl("HEADACHE", dems$`ED Visit - 15 Days Reason`), "Headache",
ifelse(grepl("EENT|NASAL CONGESTION", dems$`ED Visit - 15 Days Reason`), "EENT Non-Specified",
ifelse(grepl("DOG BITE|URIN|DIARRHEA|BRAIN|CHEST|FUSSY|BURN|FEEDING TUBE|FOREIGN|SYNCOPE|SWELLING", dems$`ED Visit - 15 Days Reason`),
"Non-ENT Related",
ifelse(grepl("OTHER", dems$`ED Visit - 15 Days Reason`), "Other",
ifelse(grepl("POST-OP", dems$`ED Visit - 15 Days Reason`), "Post-Op Problems", "Other")))))))))))))
dems$ed_15day_reason <- ifelse(is.na(dems$`ED Visit - 15 Days Reason`), NA, dems$ed_15day_reason)
# Unplanned phone call reason
all_dat$unplanned_phone_reason <- ifelse(all_dat$upcall_rsn___1 == 1, "Bleeding",
ifelse(all_dat$upcall_rsn___4 == 1, "Throat Pain",
ifelse(all_dat$upcall_rsn___6 == 1, "Nausea/Vomitting",
ifelse(all_dat$upcall_rsn___2 == 1, "Fever",
ifelse(all_dat$upcall_rsn___7 == 1, "Constipation",
ifelse(all_dat$upcall_rsn___3 == 1, "Drinking",
ifelse(all_dat$upcall_rsn___5 == 1, "Stiff Neck",
ifelse(all_dat$upcall_rsn___8 == 1, "Bad Breath",
ifelse(all_dat$upcall_rsn___9 == 1, "Belly Pain", NA)))))))))
dems$unplanned_phone_reason <- all_dat$unplanned_phone_reason[match(dems$MRN, all_dat$mrn)]
## Pull year of admission
dems$`Admission Year` <- as.numeric(substr(dems$`Admission Date`, 1, 4))
## Calculate discharge time
# Continuous for same day patients only
dems$`PACU Arrival Time` <- all_dat$pacu_arrv_time[match(dems$MRN, all_dat$mrn)]
dems$`Discharge Time` <- as.POSIXct(paste(dems$`Discharge Date`, substr(dems$`Discharge Time`, 12, 19)),
format = "%Y-%m-%d %H:%M:%OS", tz = "UTC")
dems$time_to_discharge <- (dems$`Discharge Time` - dems$`PACU Arrival Time`)/3600
dems$time_to_discharge <- ifelse(dems$discharge_group == "Stayed Over Night", NA, dems$time_to_discharge)
meds$time_to_discharge <- dems$time_to_discharge[match(meds$patient_mrn, dems$MRN)]
# Morning or Afternoon for overnight patients
dems$morning_afternoon_discharge <- ifelse(dems$`Discharge Time` > as.POSIXct("1899-12-31 12:00:00"),
"Afternoon", "Morning")
dems$morning_afternoon_discharge <- ifelse(dems$discharge_group == "Same Day Discharge", NA,
dems$morning_afternoon_discharge)
meds$morning_afternoon_discharge <- dems$morning_afternoon_discharge[match(meds$patient_mrn, dems$MRN)]
## Categorize the medications
# Narcotics, Oxy, Acetaminophin
meds$oxycodone <- ifelse(grepl("oxycodone", meds$gen_name, ignore.case = T), "Yes", "No")
meds$acetaminophin <- ifelse(grepl("Acetaminophen", meds$gen_name, ignore.case = T), "Yes", "No")
meds$narcotic <- ifelse(grepl("oxycodone|fentanyl|morphine|hydromorphone", meds$gen_name, ignore.case = T),
"Yes", "No")
meds$ibuprofen <- ifelse(grepl("Ibuprofen", meds$gen_name, ignore.case = T), "Yes", "No")
###########
## Clean up demographic variables
###########
# Age has a mo of yrs unit - convert all to months
dems$age_unit <- sapply(strsplit(dems$`Patient Age on Procedure Date`," "), `[`, 2)
dems$`Patient Age on Procedure Date` <- as.numeric(sapply(strsplit(dems$`Patient Age on Procedure Date`," "), `[`, 1))
dems$`Patient Age on Procedure Date (Months)` <- ifelse(dems$age_unit == "yrs",
dems$`Patient Age on Procedure Date`*12,
dems$`Patient Age on Procedure Date`)
# Race
dems$Race <- ifelse(grepl("More than one Race", dems$Race), "More than one Race",
ifelse(grepl("\n", dems$Race), "More than one Race",
ifelse(grepl("Asian", dems$Race), "Asian",
ifelse(grepl("Black/African American", dems$Race), "Black/African American",
ifelse(grepl("Native Hawaiian/Other Pacific Islander", dems$Race), "Native Hawaiian/Other Pacific Islander",
ifelse(grepl("American Indian/Alaska Native", dems$Race), "American Indian/Alaska Native",
ifelse(grepl("White/Caucasian", dems$Race), "White/Caucasian",
ifelse(grepl("Other", dems$Race), "Other",
ifelse(grepl("Unknown | Reported | Decline", dems$Race), "Unknown",
ifelse(dems$Race %in% c("Decline to Answer", "Not Reported"), "Unknown", dems$Race))))))))))
# Sex and Ethnicity
dems$Sex <- ifelse(dems$Sex == "F", "Female", "Male")
dems$`Hispanic Ethnicity` <- ifelse(dems$`Hispanic Ethnicity` == "Y", "Hispanic/Latinx", "Non-Hispanic/Latinx")
# ED Visit
dems$`ED Visit - 15 Days` <- factor(dems$`ED Visit - 15 Days`, levels = c(0,1), labels = c("No", "Yes"))
dems$`ED Visit - 2 Days` <- factor(dems$`ED Visit - 2 Days`, levels = c(0,1), labels = c("No", "Yes"))
dems$`Readmission - 15 Days` <- factor(dems$`Readmission - 15 Days`, levels = c(0,1), labels = c("No", "Yes"))
dems <- dems[,c(1:4, 33, 5:32, 34:77)]
dems$`Lead Surgeon/Provider` <- all_dat$surgeon[match(dems$MRN, all_dat$mrn)]
dems$Date
small_data <- dems %>%
dplyr::select(MRN, `Patient Name`, Date, DOB, `Lead Surgeon/Provider`, `Patient Age on Procedure Date`,
intra_extra, discharge_group, morning_afternoon_discharge,
Race, `Hispanic Ethnicity`, `Weight`, `Height`, `BMI Percentile`, `ASA Rating`,
`Procedures`, `Postop Opioid Prescription`, `ED Visit - 2 Days`, ed_2day_reason,
`ED Visit - 15 Days`, ed_15day_reason, `Readmission - 2 Days`,
`Readmission - 15 Days`, `Complications`, unplanned_phone_reason) %>%
mutate(timing = ifelse(Date < as.Date("2023-07-01", format = "%Y-%m-%d"), "Prior to July 2023", "After July 2023"))
write.csv(small_data, "~/Documents/Friedman - Post Op Pain/Data/TA Cleaned with Surgeon.csv")
small_data <- dems %>%
dplyr::select(MRN, `Patient Name`, Date, DOB, `Lead Surgeon/Provider`, `Patient Age on Procedure Date`,
intra_extra, discharge_group, morning_afternoon_discharge,
Race, `Hispanic Ethnicity`, `Weight`, `Height`, `BMI Percentile`, `ASA Rating`,
`Procedures`, `Postop Opioid Prescription`, `ED Visit - 2 Days`, ed_2day_reason,
`ED Visit - 15 Days`, ed_15day_reason, `Readmission - 2 Days`,
`Readmission - 15 Days`, `Complications`, unplanned_phone_reason) %>%
mutate(timing = ifelse(Date < as.Date("2023-07-01", format = "%Y-%m-%d"), "Prior to July 2023", "After July 2023")) %>%
mutate(unplanned_call = ifelse(!is.na(unplanned_phone_reason), "Yes", "No"))
write.csv(small_data, "~/Documents/Friedman - Post Op Pain/Data/TA Cleaned with Surgeon.csv")
## Load data
dat <- read.csv("~/Documents/Friedman - Post Op Pain/Data/TA Cleaned with Surgeon.csv") %>% clean_names()
View(dat)
## Create surgeon dataset
surgeon_dat <- dat %>%
# pull variables you need
dplyr::select(lead_surgeon_provider, unplanned_call, unplanned_phone_reason, ed_visit_15_days, ed_15day_reason,
readmission_15_days, intra_extra) %>%
# filter to before July 2023
filter(timing == "Prior to July 2023")
