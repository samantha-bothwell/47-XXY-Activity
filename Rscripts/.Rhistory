summarise(`Total Surgeries` = n(),
`N(%) Unplanned Phone Calls` = paste0(sum(unplanned_call == "Yes", na.rm = T), " (",
round((sum(unplanned_call == "Yes", na.rm = T)/`Total Surgeries`)*100, 1),
"%)"),
`N(%) 15 Day ED Visits` = paste0(sum(ed_visit_15_days == "Yes", na.rm = T), " (",
round((sum(ed_visit_15_days == "Yes", na.rm = T)/`Total Surgeries`)*100, 1),
"%)"),
`N(%) 15 Day Readmission` = paste0(sum(readmission_15_days == "Yes", na.rm = T), " (",
round((sum(readmission_15_days == "Yes", na.rm = T)/`Total Surgeries`)*100, 1),
"%)"),
`N(%) Intracapsular` = paste0(sum(intra_extra == "Intracapsular", na.rm = T), " (",
round((sum(intra_extra == "Intracapsular", na.rm = T)/`Total Surgeries`)*100, 1),
"%)"),
`N(%) Extracapsular` = paste0(sum(intra_extra == "Extracapsular", na.rm = T), " (",
round((sum(intra_extra == "Extracapsular", na.rm = T)/`Total Surgeries`)*100, 1),
"%)")) %>%
arrange(-`Total Surgeries`) %>%
filter(!is.na(lead_surgeon_provider))
