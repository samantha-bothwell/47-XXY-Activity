ungroup() %>%
arrange(-`Total Surgeries`) %>%
group_by(lead_surgeon_provider, ed_15day_reason) %>%
summarise(N = n(), Percent = (N/`Total Surgeries`)*100)
surgeon_dat %>%
dplyr::select(lead_surgeon_provider, ed_15day_reason) %>%
group_by(lead_surgeon_provider) %>%
mutate(`Total Surgeries` = n()) %>%
filter(!is.na(ed_15day_reason)) %>%
ungroup() %>%
arrange(`Total Surgeries`) %>%
group_by(lead_surgeon_provider, ed_15day_reason) %>%
summarise(N = n(), Percent = (N/`Total Surgeries`)*100)
surgeon_dat %>%
dplyr::select(lead_surgeon_provider, ed_15day_reason) %>%
group_by(lead_surgeon_provider) %>%
mutate(`Total Surgeries` = n()) %>%
filter(!is.na(ed_15day_reason)) %>%
ungroup() %>%
group_by(lead_surgeon_provider, ed_15day_reason) %>%
summarise(`Total Surgeries` = `Total Surgeries`, N = n(), Percent = (N/`Total Surgeries`)*100)
surgeon_dat %>%
dplyr::select(lead_surgeon_provider, ed_15day_reason) %>%
group_by(lead_surgeon_provider) %>%
mutate(`Total Surgeries` = n()) %>%
filter(!is.na(ed_15day_reason)) %>%
ungroup() %>%
group_by(lead_surgeon_provider, ed_15day_reason) %>%
summarise(`Total Surgeries` = `Total Surgeries`, `N (%)` = paste0(n(), (n()/`Total Surgeries`)*100)) %>%
pivot_wider(names_from = ed_15day_reason, values_from = `N (%)`)
surgeon_dat %>%
dplyr::select(lead_surgeon_provider, ed_15day_reason) %>%
group_by(lead_surgeon_provider) %>%
mutate(`Total Surgeries` = n()) %>%
filter(!is.na(ed_15day_reason)) %>%
ungroup() %>%
group_by(lead_surgeon_provider, ed_15day_reason) %>%
summarise(`Total Surgeries` = `Total Surgeries`, `N (%)` = paste0(n(), (n()/`Total Surgeries`)*100)) %>%
slice(1) %>%
pivot_wider(names_from = ed_15day_reason, values_from = `N (%)`)
surgeon_dat %>%
dplyr::select(lead_surgeon_provider, ed_15day_reason) %>%
group_by(lead_surgeon_provider) %>%
mutate(`Total Surgeries` = n()) %>%
filter(!is.na(ed_15day_reason)) %>%
ungroup() %>%
group_by(lead_surgeon_provider, ed_15day_reason) %>%
summarise(`Total Surgeries` = `Total Surgeries`, `N (%)` = paste0(n(), " (", round((n()/`Total Surgeries`)*100, 1), "%)")) %>%
slice(1) %>%
pivot_wider(names_from = ed_15day_reason, values_from = `N (%)`)
surgeon_dat %>%
dplyr::select(lead_surgeon_provider, ed_15day_reason) %>%
group_by(lead_surgeon_provider) %>%
mutate(`Total Surgeries` = n()) %>%
filter(!is.na(ed_15day_reason)) %>%
ungroup() %>%
group_by(lead_surgeon_provider, ed_15day_reason) %>%
summarise(`Total Surgeries` = `Total Surgeries`, `N (%)` = paste0(n(), " (", round((n()/`Total Surgeries`)*100, 1), "%)")) %>%
slice(1) %>%
pivot_wider(names_from = ed_15day_reason, values_from = `N (%)`) %>%
arrange(-`Total Surgeries`)
